---
import Base from './Base.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  draft?: boolean;
  readingTime?: number;
}

const { title, description, date, tags, draft = false, readingTime = 1 } = Astro.props;

// Fetch all posts for the search modal
const allPostsRaw = await getCollection('blog', ({ data }) => !data.draft);
const allPosts = allPostsRaw.map((p) => ({
  slug: p.slug,
  title: p.data.title,
  description: p.data.description,
  tags: p.data.tags,
}));

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const mentionTargetUrl = new URL(Astro.url.pathname, Astro.site).toString();
const mentionCountApi = `https://webmention.io/api/count?target=${encodeURIComponent(mentionTargetUrl)}`;
---

<Base
  title={`${title} | Amaan Ul Haq Siddiqui`}
  description={description}
  ogTitle={title}
  ogDescription={description}
  ogType="article"
  allPosts={allPosts}
>
  <!-- Scroll progress bar -->
  <div class="progress-bar" id="progress-bar"></div>

  <article>
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 font-mono text-xs text-muted mb-8">
      <a href="/" class="hover:text-accent">home</a>
      <span>/</span>
      <a href="/blog" class="hover:text-accent">blog</a>
      <span>/</span>
      <span class="text-text truncate max-w-[200px] sm:max-w-none">{title}</span>
    </nav>

    <header class="mb-10">
      {draft && (
        <div class="mb-4">
          <span class="badge badge-orange">Draft</span>
        </div>
      )}

      <h1 class="font-mono text-2xl sm:text-3xl text-text leading-tight mb-5">
        {title}
      </h1>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-muted font-mono">
        <time datetime={date.toISOString()} class="flex items-center gap-1.5">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="2" width="14" height="13" rx="2"/>
            <path d="M1 6h14M5 1v2M11 1v2"/>
          </svg>
          {formattedDate}
        </time>
        <span class="flex items-center gap-1.5">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="8" cy="8" r="7"/>
            <path d="M8 4v4l3 2"/>
          </svg>
          {readingTime} min read
        </span>
        <span class="flex items-center gap-1.5" title="Webmentions received for this post">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 3h10v7H8l-3 3v-3H3z"/>
          </svg>
          <span id="webmention-count">0 mentions</span>
        </span>
      </div>

      <p class="mt-5 text-muted text-sm leading-relaxed max-w-prose border-l-2 border-border pl-4">
        {description}
      </p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-5">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>

    <div class="border-t border-border mb-10"></div>

    <div class="prose" id="post-content">
      <slot />
    </div>

    <div class="mt-14 pt-6 border-t border-border flex items-center justify-between">
      <a href="/blog" class="font-mono text-sm text-muted hover:text-accent flex items-center gap-2 group">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform">
          <path d="M10 12L6 8l4-4"/>
        </svg>
        Back to blog
      </a>
      <button
        onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
        class="font-mono text-xs text-muted hover:text-accent flex items-center gap-1.5 cursor-pointer border-none bg-transparent"
      >
        Top
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 12V4M4 8l4-4 4 4"/>
        </svg>
      </button>
    </div>
  </article>

  <script is:inline define:vars={{ mentionCountApi }}>
    // Scroll progress bar
    const bar = document.getElementById('progress-bar');
    const content = document.getElementById('post-content');
    const mentionCountEl = document.getElementById('webmention-count');

    function updateProgress() {
      if (!bar || !content) return;
      const rect = content.getBoundingClientRect();
      const contentTop = rect.top + window.scrollY;
      const contentHeight = content.offsetHeight;
      const scrolled = window.scrollY - contentTop;
      const pct = Math.min(100, Math.max(0, (scrolled / contentHeight) * 100));
      bar.style.width = pct + '%';
    }

    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();

    fetch(mentionCountApi)
      .then((response) => {
        if (!response.ok) throw new Error('Failed to load mentions');
        return response.json();
      })
      .then((data) => {
        const count = typeof data?.count === 'number' ? data.count : 0;
        if (mentionCountEl) {
          mentionCountEl.textContent = count === 1 ? '1 mention' : `${count} mentions`;
        }
      })
      .catch(() => {
        if (mentionCountEl) mentionCountEl.textContent = 'Mentions unavailable';
      });
  </script>
</Base>
