---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const allPosts = await getCollection('blog', ({ data, id }) => !data.draft && !id.endsWith('.draft.md'));
const allPostsData = allPosts.map((p) => ({
  slug: p.slug,
  title: p.data.title,
  description: p.data.description,
  tags: p.data.tags,
}));

const accounts = [
  {
    platform: 'GitHub',
    handle: 'github.com/amaanx86',
    url: 'https://github.com/amaanx86',
    notes: 'Primary OSS account',
  },
  {
    platform: 'GitLab',
    handle: 'gitlab.com/amaanx86',
    url: 'https://gitlab.com/amaanx86',
    notes: 'OSS & work projects',
  },
  {
    platform: 'LinkedIn',
    handle: 'linkedin.com/in/amaanulhaqsiddiqui',
    url: 'https://www.linkedin.com/in/amaanulhaqsiddiqui/',
    notes: 'Professional',
  },
  {
    platform: 'AWS Builder ID',
    handle: 'builder.aws.com/community/@amaan100x',
    url: 'https://builder.aws.com/community/@amaan100x',
    notes: 'AWS community profile',
  },
  {
    platform: 'Credly',
    handle: 'credly.com/users/amaanx86',
    url: 'https://www.credly.com/users/amaanx86',
    notes: 'Certifications & badges',
  },
  {
    platform: 'ORCID',
    handle: '0009-0003-4839-9727',
    url: 'https://orcid.org/0009-0003-4839-9727',
    notes: 'Research identity',
  },
  {
    platform: 'DEV.to',
    handle: 'dev.to/amaanx86',
    url: 'https://dev.to/amaanx86',
    notes: 'Technical writing',
  },
  {
    platform: 'X (Twitter)',
    handle: 'x.com/amaanx86',
    url: 'https://x.com/amaanx86',
    notes: 'Listed for verification; not actively used',
  },
  {
    platform: 'Reddit',
    handle: 'u/The404Engineer',
    url: 'https://reddit.com/user/The404Engineer/',
    notes: 'Technical discussions',
  },
  {
    platform: 'Email',
    handle: 'amaanulhaq.s@outlook.com',
    url: null,
    notes: 'PGP-signed preferred',
  },
];
---

<Base
  title="Verify my identity | Amaan Ul Haq Siddiqui"
  description="Canonical record of Amaan Ul Haq Siddiqui's online presence and cryptographic identity."
  allPosts={allPostsData}
>
  <div class="space-y-12">
    <!-- Header -->
    <div>
      <h1 class="font-mono text-2xl text-text font-semibold mb-3">Verify my identity</h1>
      <p class="text-sm text-muted leading-relaxed max-w-prose">
        This page is the canonical record of my online presence and cryptographic identity. Use it to protect against phishing, verify signed code commits, and authenticate encrypted communication. If an account is not listed here, it is not me. Accounts claiming to be me elsewhere should be treated as imposters.
      </p>
    </div>

    <!-- GPG section -->
    <section class="space-y-4">
      <h2 class="font-mono text-xs text-muted uppercase tracking-widest">GPG Key</h2>

      <div class="card space-y-5">
        <!-- Key ID + algo -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          <div>
            <div class="font-mono text-xs text-muted uppercase tracking-wide mb-1.5">Key ID</div>
            <code class="font-mono text-sm text-accent">FC47DEE803DB612A</code>
          </div>
          <div>
            <div class="font-mono text-xs text-muted uppercase tracking-wide mb-1.5">Algorithm</div>
            <code class="font-mono text-sm text-text">RSA 4096</code>
          </div>
          <div>
            <div class="font-mono text-xs text-muted uppercase tracking-wide mb-1.5">Email</div>
            <code class="font-mono text-sm text-text">amaanulhaq.s@outlook.com</code>
          </div>
        </div>

        <!-- Fingerprint -->
        <div>
          <div class="font-mono text-xs text-muted uppercase tracking-wide mb-2">Full fingerprint</div>
          <div class="bg-surface-raised border border-border rounded-md px-4 py-3 font-mono text-sm text-text break-all leading-relaxed tracking-wide">
            9A1D B246 6C1A 9E94 F7DF&nbsp;&nbsp;38C3 FC47 DEE8 03DB 612A
          </div>
        </div>

        <!-- Actions -->
        <div class="flex flex-wrap gap-3 pt-2 border-t border-border">
          <a
            href="https://keyserver.ubuntu.com/pks/lookup?search=amaanulhaq.s%40outlook.com&fingerprint=on&op=index"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-mono text-accent border border-accent/30 bg-accent-bg hover:bg-accent/10 rounded-md px-3 py-1.5 no-underline transition-colors"
          >
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="8" cy="8" r="7"/>
              <path d="M8 4v4l3 2"/>
            </svg>
            Keyserver lookup
          </a>
          <a
            href="/amaan.asc"
            download
            class="inline-flex items-center gap-2 text-sm font-mono text-muted border border-border hover:border-accent hover:text-accent bg-surface rounded-md px-3 py-1.5 no-underline transition-colors"
          >
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 1v9M5 7l3 3 3-3M2 12v1a2 2 0 002 2h8a2 2 0 002-2v-1"/>
            </svg>
            Download .asc
          </a>
        </div>

        <!-- GPG Usage -->
        <div class="text-sm text-muted border-t border-border pt-4 leading-relaxed">
          <p>Use this key to verify signed commits, releases, and secure communication. Never trust unsigned claims from anyone. Always verify against this canonical fingerprint.</p>
        </div>
      </div>
    </section>

    <!-- Corporate GPG Keys -->
    <section class="space-y-4">
      <h2 class="font-mono text-xs text-muted uppercase tracking-widest">Corporate GPG Keys</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="card space-y-3">
          <div>
            <div class="font-mono text-xs text-muted uppercase tracking-wide mb-3">SUDO Consultants</div>
            <div class="space-y-2 mb-4 border-b border-border pb-4">
              <div>
                <div class="font-mono text-xs text-muted uppercase tracking-wide mb-1">Key ID</div>
                <code class="font-mono text-sm text-accent">0B1255FF6B0D509B</code>
              </div>
              <div>
                <div class="font-mono text-xs text-muted uppercase tracking-wide mb-1">Algorithm</div>
                <code class="font-mono text-sm text-text">RSA 4096</code>
              </div>
            </div>
            <a
              href="https://keyserver.ubuntu.com/pks/lookup?search=amaanulhaq.siddiqui%40sudoconsultants.com&fingerprint=on&op=index"
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-accent hover:text-accent-hover"
            >
              View on keyserver →
            </a>
          </div>
        </div>

        <div class="card space-y-3">
          <div>
            <div class="font-mono text-xs text-muted uppercase tracking-wide mb-3">MISK Foundation</div>
            <div class="space-y-2 mb-4 border-b border-border pb-4">
              <div>
                <div class="font-mono text-xs text-muted uppercase tracking-wide mb-1">Key ID</div>
                <code class="font-mono text-sm text-accent">A1FA15D51F6C8D6D</code>
              </div>
              <div>
                <div class="font-mono text-xs text-muted uppercase tracking-wide mb-1">Algorithm</div>
                <code class="font-mono text-sm text-text">RSA 4096</code>
              </div>
            </div>
            <a
              href="https://keyserver.ubuntu.com/pks/lookup?search=v-aman.siddiqui%40misk.org.sa&fingerprint=on&op=index"
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-accent hover:text-accent-hover"
            >
              View on keyserver →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Identity table -->
    <section class="space-y-4">
      <h2 class="font-mono text-xs text-muted uppercase tracking-widest">Verified accounts</h2>

      <div class="card p-0 overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border bg-surface-raised">
              <th class="text-left font-mono text-xs text-muted uppercase tracking-wide px-5 py-3">Platform</th>
              <th class="text-left font-mono text-xs text-muted uppercase tracking-wide px-5 py-3">Handle / URL</th>
              <th class="text-left font-mono text-xs text-muted uppercase tracking-wide px-5 py-3 hidden sm:table-cell">Notes</th>
            </tr>
          </thead>
          <tbody>
            {accounts.map((acct, i) => (
              <tr class={`border-b border-border last:border-0 hover:bg-surface-raised transition-colors`}>
                <td class="px-5 py-3.5 font-mono text-xs text-muted whitespace-nowrap">{acct.platform}</td>
                <td class="px-5 py-3.5">
                  {acct.url ? (
                    <a
                      href={acct.url}
                      target="_blank"
                      rel="me noopener noreferrer"
                      class="font-mono text-sm text-accent hover:text-accent-hover no-underline"
                    >
                      {acct.handle}
                    </a>
                  ) : (
                    <span class="font-mono text-sm text-text">{acct.handle}</span>
                  )}
                </td>
                <td class="px-5 py-3.5 text-xs text-muted hidden sm:table-cell">{acct.notes}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- What to do if you find an imposter -->
    <section class="space-y-4">
      <h2 class="font-mono text-xs text-muted uppercase tracking-widest">If you find an imposter</h2>
      <div class="card bg-surface-raised">
        <ul class="text-sm text-muted leading-relaxed space-y-2 list-disc list-inside">
          <li>Report the account to the platform immediately</li>
          <li>Cross-reference the imposter's claims against accounts listed on this page</li>
          <li>Contact me directly via email if you have security concerns</li>
          <li>Do not trust unverified GPG signatures. Verify the fingerprint above</li>
        </ul>
      </div>
    </section>

    <!-- Canonical note -->
    <section>
      <div class="card bg-surface-raised border-dashed">
        <div class="flex items-start gap-3">
          <svg class="text-muted mt-0.5 flex-shrink-0" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="8" cy="8" r="7"/><path d="M8 7v5M8 5h.01"/>
          </svg>
          <p class="font-mono text-xs text-muted leading-relaxed">
            This page is served from{' '}
            <a
              href="https://github.com/amaanx86/amaanx86.github.io"
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:text-accent-hover"
            >
              github.com/amaanx86/amaanx86.github.io
            </a>{' '}
            and can be verified against the commit history. The canonical URL is{' '}
            <code class="text-xs">https://amaanx86.github.io/verify</code>. GPG key <code class="text-xs">FC47DEE803DB612A</code> can also be found on the Ubuntu keyserver.
          </p>
        </div>
      </div>
    </section>
  </div>
</Base>
